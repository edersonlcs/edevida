{
  "name": "edevida-android",
  "version": "1.0.0",
  "description": "App Android (APK pessoal) do EdeVida via Capacitor.",
  "private": true,
  "scripts": {
    "doctor": "npx cap doctor",
    "sync": "npx cap sync android",
