    "build:release": "cd android && ./gradlew assembleRelease",
    "keystore:generate": "./scripts/generate-keystore.sh",
    "release:sign": "./scripts/sign-release.sh",
    "release:all": "./scripts/build-apk.sh release && ./scripts/sign-release.sh"
  },
